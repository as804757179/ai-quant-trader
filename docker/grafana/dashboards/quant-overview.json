  "panels": [
    {
      "type": "stat",
      "title": "熔断状态 (simulation)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "quant_risk_fuse_active{mode=\"simulation\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFF", "color": "green" }, "1": { "text": "ON", "color": "red" } } }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "WS 连接数",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "quant_ws_connections", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "告警速率 by level",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (level) (rate(quant_alerts_total[5m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "订单 by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (status) (rate(quant_orders_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "钉钉推送",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (result) (rate(quant_dingtalk_sent_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "回测完成累计",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "quant_backtest_total{status=\"done\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "回测失败累计",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "targets": [
        {
          "expr": "quant_backtest_total{status=\"failed\"}",
          "refId": "A"
        }
      ]
    }
