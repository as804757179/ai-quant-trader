# ==============================================
# AI Quant Trader Pro — 环境变量配置模板
# 复制为 .env 后填写真实值；切勿将 .env 提交到 Git
# 密码/密钥含 # $ 等特殊字符时，DATABASE_URL / REDIS_URL 请做 URL 编码
# ==============================================

# ── 数据库 ──
DB_HOST=postgres
DB_PORT=5432
DB_NAME=quant_trader
DB_USER=quant_admin
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
# 示例（密码需 URL 编码）：postgresql+asyncpg://user:pass%23word@host:5432/db
DATABASE_URL=postgresql+asyncpg://quant_admin:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/quant_trader

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ── AI 模型 API Keys ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=30

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TIMEOUT=30

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=20

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_MODEL=qwen-turbo
QWEN_TIMEOUT=20

# ── 系统配置 ──
APP_ENV=development
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
# API_KEY 已不再作为授权来源；请通过主体凭据和浏览器会话认证。
API_KEY=
API_ALLOW_ANONYMOUS_READS=true
API_LEGACY_KEY_MIGRATION_ENABLED=false
API_SESSION_COOKIE_NAME=aq_session
API_SESSION_TTL_SECONDS=28800
# Worker 服务主体凭据；使用 backend/scripts/provision_api_principal.py 创建。
WORKER_API_CREDENTIAL=replace-with-secure-random-credential
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost"]

# ── 数据同步 ──
DATA_SYNC_INTERVAL_REALTIME=3
DATA_SYNC_INTERVAL_FUNDFLOW=60
DATA_CACHE_TTL_QUOTE=15
DATA_CACHE_TTL_KLINE=300
DATA_CACHE_TTL_FUNDAMENTAL=3600

# ── 交易配置 ──
TRADE_MODE=simulation
TRADING_EXECUTION_ENABLED=false
AI_ORDER_ENABLED=false
LIVE_TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true
REQUIRE_HUMAN_APPROVAL=true
ALLOW_SCHEDULED_ORDER=false
CERTIFIED_BACKTEST_EXECUTION_ENABLED=false
CERTIFIED_SCREENER_OUTPUT_ENABLED=false
# live 无 QMT 时是否允许 Mock（开发 true，生产必须 false）
MOCK_QMT_CASH=1000000
# 实盘二次确认令牌（mode=live 必填 live_confirm）
LIVE_CONFIRM_TOKEN=CHANGE_ME_LIVE_CONFIRM
# 单笔实盘金额上限（元）
LIVE_MAX_ORDER_VALUE=50000
# 成交后自动对账
AUTO_RECONCILE_ON_FILL=true
# 真实 QMT（Windows + miniQMT）
QMT_PATH=
QMT_ACCOUNT_ID=
QMT_ACCOUNT_TYPE=STOCK
QMT_SESSION_ID=123456
QMT_FORCE_MOCK=false

# ── 回测数据 ──
BACKTEST_AUTO_BACKFILL=true
BACKTEST_ALLOW_SYNTHETIC_KLINE=false
SYNTHETIC_KLINE_SMOKE_TEST=false

# ── 风控参数 ──
MAX_SINGLE_POSITION_RATIO=0.10
WARN_SINGLE_POSITION_RATIO=0.08
MAX_TOTAL_POSITION_RATIO=0.80
MAX_DAILY_LOSS_RATIO=0.03
MAX_DRAWDOWN_RATIO=0.15
MAX_DAILY_ORDER_COUNT=20
MAX_SECTOR_CONCENTRATION_RATIO=0.40
MIN_DAILY_AMOUNT=50000000

# ── AI信号阈值 ──
SIGNAL_MIN_CONFIDENCE=0.65
SIGNAL_BUY_THRESHOLD=0.70
SIGNAL_SELL_THRESHOLD=0.30
SIGNAL_VALIDITY_HOURS=24

# ── 数据源服务 ──
A_STOCK_DATA_URL=http://a-stock-data:8080
A_STOCK_DATA_COMMAND_TOKEN=replace-with-secure-random-token

# ── ChromaDB ──
CHROMA_PERSIST_DIR=/app/vector_db
CHROMA_COLLECTION_REPORTS=research_reports
CHROMA_COLLECTION_ANNOUNCEMENTS=announcements
CHROMA_COLLECTION_NEWS=news

# ── 监控 ──
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMETHEUS_RETENTION=30d

# ── 通知（可选）──
# 钉钉自定义机器人 Webhook
DINGTALK_WEBHOOK=
ENABLE_DINGTALK_NOTIFY=false
# 推送级别，逗号分隔：CRITICAL,ERROR,WARNING,INFO
DINGTALK_ALERT_LEVELS=CRITICAL,ERROR
DINGTALK_COOLDOWN_SECONDS=300
# 静默时段（上海时区），如 23:00-08:00；空=不静默
DINGTALK_QUIET_HOURS=
DINGTALK_QUIET_BYPASS_LEVELS=CRITICAL
